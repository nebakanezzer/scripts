#!/usr/bin/env python3
import subprocess
import time
import pyautogui
import urllib.request
import urllib.error
import os
import signal

# Frigate non-auth addy
URL = "http://192.168.1.12:5000"
LOAD_DELAY = 7 # Increased slightly for full browser restarts
CHECK_INTERVAL = 900

# Global variable to keep track of the browser process
browser_process = None

def launch_browser():
    """Launches Vivaldi with specific memory-management flags for Linux."""
    global browser_process
    
    print("Launching Vivaldi...")
    # --disable-dev-shm-usage: CRITICAL for Linux video kiosks. Forces Chromium to use /tmp instead of /dev/shm, preventing memory crashes.
    # --no-default-browser-check: Stops annoying popups if it restarts.
    flags = [
        "vivaldi", URL, 
        "--new-window", 
        "--start-fullscreen",
        "--disable-dev-shm-usage", 
        "--no-default-browser-check",
        "--autoplay-policy=no-user-gesture-required"
    ]
    
    browser_process = subprocess.Popen(flags)
    
    print(f"Waiting {LOAD_DELAY}s for load...")
    time.sleep(LOAD_DELAY)

def kill_browser():
    """Forcefully kills Vivaldi to clear out memory leaks or crashed renderers."""
    global browser_process
    print("Terminating Vivaldi...")
    if browser_process:
        try:
            browser_process.terminate()
            browser_process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            browser_process.kill()
    
    # Catch-all to ensure all Vivaldi background processes are dead
    os.system("killall -9 vivaldi-bin > /dev/null 2>&1")
    time.sleep(2)

def apply_frigate_layout():
    """Applies the specific clicks and anti-inertia drags to set up the Frigate UI."""
    print("Applying Frigate layout formatting...")
    
    pyautogui.click(100, 100)
    time.sleep(1)

    print("Sending 'f' for Frigate UI Fullscreen...")
    pyautogui.press('f')
    time.sleep(5) 

    screen_width, screen_height = pyautogui.size()
    print("Clicking bottom-right to focus...")
    pyautogui.click(screen_width - 5, screen_height - 5)
    time.sleep(1) 

    print("Performing slow-anchor nudge...")
    start_x = screen_width - 20
    start_y = screen_height / 5
    target_y = start_y - 20 
    
    pyautogui.moveTo(start_x, start_y)
    pyautogui.mouseDown(button='left')
    pyautogui.moveTo(start_x, target_y, duration=1.2)
    pyautogui.moveTo(start_x, target_y + 1, duration=0.1)
    
    time.sleep(0.8)
    pyautogui.mouseUp(button='left')

    pyautogui.moveTo(screen_width - 5, screen_height - 5)
    print("Layout locked.")

def is_network_up():
    try:
        urllib.request.urlopen(URL, timeout=5)
        return True
    except (urllib.error.URLError, TimeoutError):
        return False

def is_ui_crashed(screen_width, screen_height):
    """
    Checks if the screen is purely black (Frigate timeout) 
    OR matches the Vivaldi 'Dead Bird' dark gray.
    """
    r, g, b = pyautogui.pixel(int(screen_width / 2), int(screen_height / 2))
    
    # Timeout = pure black
    if r == 0 and g == 0 and b == 0:
        print("Detected Black Screen (Timeout).")
        return True
        
    # Dead Bird Screen = usually a uniform dark gray (around RGB 34,34,34 to 45,45,45 depending on theme)
    # We check if red, green, and blue are perfectly equal and in that dark gray range.
    if r == g and g == b and 20 <= r <= 50:
        print(f"Detected Dead Bird Gray (RGB: {r},{g},{b}).")
        return True
        
    return False

def main():
    launch_browser()
    apply_frigate_layout()

    screen_width, screen_height = pyautogui.size()
    print(f"Starting watchdog loop. Checking every {CHECK_INTERVAL} seconds...")
    
    while True:
        time.sleep(CHECK_INTERVAL)
        
        needs_hard_restart = False

        if not is_network_up():
            print("Network drop detected. Waiting for connection to return...")
            while not is_network_up():
                time.sleep(5)
            print("Network restored!")
            needs_hard_restart = True
            
        elif is_ui_crashed(screen_width, screen_height):
            print("UI Crash or Timeout detected.")
            needs_hard_restart = True

        if needs_hard_restart:
            print("Initiating Hard Recovery Protocol...")
            kill_browser()
            launch_browser()
            apply_frigate_layout()

if __name__ == "__main__":
    main()