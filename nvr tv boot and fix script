#!/usr/bin/env python3
import subprocess
import time
import pyautogui
import urllib.request
import urllib.error

# Frigate non-auth addy
URL = "http://192.168.1.12:5000"
LOAD_DELAY = 5
CHECK_INTERVAL = 900  # How often to check if Frigate is alive (in seconds)

def apply_frigate_layout():
    """Applies the specific clicks and anti-inertia drags to set up the Frigate UI."""
    print("Applying Frigate layout formatting...")
    
    # 1. INITIAL FOCUS
    pyautogui.click(100, 100)
    time.sleep(1)

    # 2. TRIGGER FRIGATE FULLSCREEN
    print("Sending 'f' for Frigate UI Fullscreen...")
    pyautogui.press('f')
    time.sleep(1) 

    # 3. THE LAYER-BREAKING CLICK
    screen_width, screen_height = pyautogui.size()
    print("Clicking bottom-right to focus...")
    pyautogui.click(screen_width - 5, screen_height - 5)
    time.sleep(1) 

    # 4. THE CONTROLLED SLOW DRAG (Anti-Inertia)
    print("Performing slow-anchor nudge...")
    start_x = screen_width - 20
    start_y = screen_height / 5
    target_y = start_y - 20 
    
    pyautogui.moveTo(start_x, start_y)
    pyautogui.mouseDown(button='left')
    pyautogui.moveTo(start_x, target_y, duration=1.2)
    pyautogui.moveTo(start_x, target_y + 1, duration=0.1)
    
    time.sleep(0.8)
    pyautogui.mouseUp(button='left')

    # 5. PARK THE MOUSE
    pyautogui.moveTo(screen_width - 5, screen_height - 5)
    print("Layout locked.")

def is_network_up():
    """Checks if the Frigate server is reachable on the network."""
    try:
        urllib.request.urlopen(URL, timeout=5)
        return True
    except (urllib.error.URLError, TimeoutError):
        return False

def is_ui_timed_out(screen_width, screen_height):
    """
    Checks if the video feed has timed out by looking at a specific pixel.
    If the Frigate UI times out, the video feed usually goes black or dark gray.
    """
    # Sample a pixel dead-center on the screen
    r, g, b = pyautogui.pixel(int(screen_width / 2), int(screen_height / 2))
    
    # If the pixel is pure black, assume the video feed died.
    # NOTE: You may need to change (0,0,0) to match the exact background 
    # color Frigate shows when a camera disconnects.
    if r == 0 and g == 0 and b == 0:
        return True
    return False

def main():
    print("Launching Vivaldi...")
    subprocess.Popen(["vivaldi", URL, "--new-window", "--start-fullscreen"])

    print(f"Waiting {LOAD_DELAY}s for load...")
    time.sleep(LOAD_DELAY)

    # Do the initial layout setup
    apply_frigate_layout()

    # Get screen dimensions for the visual watchdog
    screen_width, screen_height = pyautogui.size()

    print(f"Starting watchdog loop. Checking every {CHECK_INTERVAL} seconds...")
    
    # --- THE WATCHDOG LOOP ---
    while True:
        time.sleep(CHECK_INTERVAL)
        
        needs_refresh = False

        # Check 1: Did the Debian machine drop its WiFi connection?
        if not is_network_up():
            print("Network drop detected. Waiting for connection to return...")
            # Pause the script here until the network comes back
            while not is_network_up():
                time.sleep(5)
            print("Network restored!")
            needs_refresh = True
            
        # Check 2: Did the Frigate UI time out while the network was fine?
        elif is_ui_timed_out(screen_width, screen_height):
            print("UI Timeout detected (Screen went black).")
            needs_refresh = True

        # If either check failed, refresh the browser and re-apply the layout
        if needs_refresh:
            print("Refreshing Vivaldi...")
            # Click the screen to ensure Vivaldi is still the active window
            pyautogui.click(screen_width - 5, screen_height - 5)
            time.sleep(0.5)
            
            # Send F5 to refresh the page
            pyautogui.press('f5')
            
            # Wait for the page to reload
            print(f"Waiting {LOAD_DELAY}s for reload...")
            time.sleep(LOAD_DELAY)
            
            # Re-apply your custom formatting
            apply_frigate_layout()

if __name__ == "__main__":
    main()
